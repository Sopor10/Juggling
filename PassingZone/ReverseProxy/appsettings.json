{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "ffmpeg-route": {
        "ClusterId": "LocalCluster",
        "Match": { "Path": "/ffmpeg/{**catch-all}" }
      },
      "mcp-route": {
        "ClusterId": "LocalClusterMcp",
        "Match": { "Path": "/mcp/{**catch-all}" }
      }
    },
    "Clusters": {
      "LocalCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://ffmpeg.host:8080"
          }
        }
      },
      "LocalClusterMcp": {
        "Destinations": {
          "Destination1": {
            "Address": "http://siteswaps.mcp.server:8080"
          }
        }
      }
    }
  }
}
