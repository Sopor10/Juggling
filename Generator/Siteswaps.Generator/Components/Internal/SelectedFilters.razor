@using Siteswaps.Generator.Components.State.FilterTrees
@inherits FluxorComponent

@inject IDispatcher Dispatcher
@inject IState<SiteswapGeneratorState> State
@inject IDialogService DialogService
@inject DialogTracker DialogTracker

<div class="p-0 p-lg-3">
    <div class="w-100">
        <MudTreeView T="FilterNode" Dense="true" Style="width: 100%; height: 300px; overflow-y: auto;">
            @foreach (var entry in entries)
            {
                @RenderNode(entry)
            }
        </MudTreeView>
    </div>
</div>

@code {
    IEnumerable<FilterNode> entries => new[]{Tree.Root }.OfType<FilterNode>();
    private FilterTree Tree => State.Value.State.FilterTree;

    private RenderFragment RenderNode(FilterNode node) => __builder =>
    {
        <MudTreeViewItem T="FilterNode" Value="@node" Expanded="true">
            <BodyContent Context="_treeItem">
                @switch (node)
                {
                    case AndNode andNode:
                        <div class="d-flex align-items-center gap-1" data-testid="@TreeTestId(andNode)">
                            <MudText Typo="Typo.body2" Class="me-1"><b>And</b></MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Title="Add Or" Disabled="@(!andNode.Children.Any(x => x is OrNode or FilterLeaf))" OnClick="@(() => Dispatcher.Dispatch(new AddOrFilterAction(Tree.GetKey(andNode))))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Title="Add Filter" OnClick="@(async () => { var k = Tree.GetKey(andNode); if (k is not null) await AddNewFilter(k); })" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Title="Remove" Disabled="@(Tree.Root == andNode)" OnClick="@(() => Dispatcher.Dispatch(new RemoveFilter(andNode)))" Color="Color.Error" />
                        </div>
                        break;
                    case OrNode orNode:
                        <div class="d-flex align-items-center gap-1" data-testid="@TreeTestId(orNode)">
                            <MudText Typo="Typo.body2" Class="me-1"><b>Or</b></MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.MergeType" Size="Size.Small" Title="Add And" Disabled="@(!orNode.Children.Any(x => x is AndNode or FilterLeaf))" OnClick="@(() => Dispatcher.Dispatch(new AddAndFilterAction(Tree.GetKey(orNode))))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Title="Add Filter" OnClick="@(async () => { var k = Tree.GetKey(orNode); if (k is not null) await AddNewFilter(k); })" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Title="Remove" OnClick="@(() => Dispatcher.Dispatch(new RemoveFilter(orNode)))" Color="Color.Error" />
                        </div>
                        break;
                    case FilterLeaf leaf:
                        <div class="card w-100 h-100 flex-grow-1" data-testid="@TreeTestId(leaf)">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <div class="d-flex justify-content-between align-items-center">
                                    <text class="text-break">@(leaf.Filter.Display())</text>
                                    <div class="d-flex">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => ShowInlineDialog(leaf)" data-testid="@EditFilterTestId(leaf)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => Dispatcher.Dispatch(new RemoveFilter(leaf))" data-testid="@DeleteFilterTestId(leaf)" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        break;
                }
            </BodyContent>
            <ChildContent>
                @{
                    IEnumerable<FilterNode> children = node switch
                    {
                        AndNode a => a.Children,
                        OrNode o => o.Children,
                        _ => []
                    };
                    foreach (var child in children)
                    {
                        @RenderNode(child)
                    }
                }
            </ChildContent>
        </MudTreeViewItem>
    };

    private async Task ShowInlineDialog(FilterLeaf i)
    {
        var dialog = await DialogService.ShowAsync<Filter>(
            "Edit Filter",
            new DialogParameters<Filter> { { x => x.FilterNumber, i } },
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true }
        );
        DialogTracker.CurrentDialog = dialog;
    }

    public record RemoveFilter(FilterNode Value);

    [ReducerMethod]
    public static SiteswapGeneratorState ReduceRemoveFilterAction(
        SiteswapGeneratorState state,
        RemoveFilter action
    )
    {
        return state with
        {
            State = state.State with { FilterTree = state.State.FilterTree.Remove(action.Value) }
        };
    }

    public record AddOrFilterAction(string? Key);
    public record AddAndFilterAction(string? Key);
    
    [ReducerMethod]
    public static SiteswapGeneratorState ReduceOrFilterAction(
        SiteswapGeneratorState state,
        AddOrFilterAction action
    )
    {
        if (action.Key is null)
        {
            return state;
        }

        var filterNode = state.State.FilterTree.FindNode(action.Key);
        if (filterNode is null)
        {
            return state;
        }
        return state with
        {
            State = state.State with { FilterTree = state.State.FilterTree.Add(filterNode, new OrNode()) }
        };
    }
    [ReducerMethod]
    public static SiteswapGeneratorState ReduceAddFilterAction(
        SiteswapGeneratorState state,
        AddAndFilterAction action
    )
    {
        if (action.Key is null)
        {
            return state;
        }
        var filterNode = state.State.FilterTree.FindNode(action.Key);
        if (filterNode is null)
        {
            return state;
        }
        return state with
        {
            State = state.State with { FilterTree = state.State.FilterTree.Add(filterNode, new AndNode()) }
        };
    }
    
    private async Task AddNewFilter(string key)
    {
        var dialog = await DialogService.ShowAsync<Filter>(
            "New Pattern Filter",
            new DialogParameters<Filter> { { x => x.Key, key } },
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true }
        );
        DialogTracker.CurrentDialog = dialog;
    }
    
    private string TreeTestId(FilterNode node) => $"filter-node-{State.Value.State.FilterTree.GetKey(node)}";
    private string EditFilterTestId(FilterLeaf leaf) => $"edit-filter-{State.Value.State.FilterTree.GetKey(leaf)}";

    private string DeleteFilterTestId(FilterLeaf leaf) => $"delete-filter-{State.Value.State.FilterTree.GetKey(leaf)}";
}
